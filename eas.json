{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "beta"
    },
    "preview": {
      "distribution": "internal",
      "channel": "beta"
    },
    "preview-apk": {
      "distribution": "internal",
      "channel": "beta",
      "android": {
        "buildType": "apk"
      }
    },
    "beta": {
      "channel": "beta",
      "android": {
        "buildType": "app-bundle",
        "enableProguardInReleaseBuilds": true
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "enableProguardInReleaseBuilds": true
      }
    }
  },
  "submit": {
    "beta": {
      "android": {
        "serviceAccountKeyPath": "./nfc-identifier-f28151ad3f34.json",
        "track": "internal"
      }
    },
    "production": {
      "android": {
        "serviceAccountKeyPath": "./nfc-identifier-f28151ad3f34.json",
        "track": "production"
      }
    }
  }
}
